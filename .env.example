# Copy to .env and fill in values

# Postgres
POSTGRES_USER=zetta
POSTGRES_PASSWORD=zetta
POSTGRES_DB=zetta
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional on Render. Locally, leave blank and use the individual Postgres values above.
DATABASE_URL=

# Redis (Celery broker + backend)
REDIS_URL=redis://redis:6379/0

# Groq LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Celery
CELERY_WORKER_POOL=threads
CELERY_WORKER_CONCURRENCY=4

# App
LOG_LEVEL=INFO
